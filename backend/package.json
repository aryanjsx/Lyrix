{
  "name": "lyrix-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "load:smoke": "k6 run load-tests/smoke.js",
    "load:baseline": "k6 run load-tests/baseline.js",
    "load:quota": "k6 run --env BASE_URL=http://localhost:4000 load-tests/quota-stress.js",
    "load:staging": "k6 run --env BASE_URL=$STAGING_URL load-tests/baseline.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.51.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "posthog-node": "^5.33.0",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "ts-node-dev": "^2.0.0"
  }
}
