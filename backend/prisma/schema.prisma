generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Track {
  id          String          @id
  title       String
  channel     String
  channelId   String?
  duration    Int
  thumbnail   String
  category    String
  filterScore Int
  cachedAt    DateTime        @default(now())
  playHistory PlayHistory[]
  playlists   PlaylistTrack[]
  savedBy     SavedTrack[]
  genres      TrackGenre[]
  lyrics      TrackLyrics?

  @@index([category])
}

model TrackLyrics {
  id         String   @id @default(cuid())
  trackId    String   @unique
  source     String
  hasSync    Boolean  @default(false)
  rawLyrics  String?  @db.LongText
  lrcContent String?  @db.LongText
  snippet    String?  @db.Text
  isPartial  Boolean  @default(false)
  language   String?
  fetchedAt  DateTime @default(now())
  expiresAt  DateTime

  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model ApiQuota {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  units     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model User {
  id                 String        @id @default(cuid())
  googleId           String        @unique
  email              String        @unique
  displayName        String
  avatarUrl          String?
  googleAccessToken  String?       @db.Text
  googleRefreshToken String?       @db.Text
  googleTokenExpiry  DateTime?
  abTestGroup            String?
  preferredLanguages     Json?
  hasCompletedOnboarding Boolean       @default(false)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  history                PlayHistory[]
  searchHistory          SearchHistory[]
  feedbackLogs           FeedbackLog[]
  userPreferences        UserPreferences?
  playlists          Playlist[]
  savedTracks        SavedTrack[]
  syncLogs           SyncLog[]
  genreProfile       UserGenreProfile[]
  artistProfile      UserArtistProfile[]
  smartMixes         SmartMix[]
}

model PlayHistory {
  id            String   @id @default(cuid())
  userId        String
  trackId       String
  playedAt      DateTime @default(now())
  secondsPlayed Int      @default(0)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track         Track    @relation(fields: [trackId], references: [id])

  @@index([userId])
  @@index([trackId])
  @@index([userId, playedAt(sort: Desc)])
  @@index([userId, trackId])
}

model SearchHistory {
  id         String   @id @default(cuid())
  userId     String
  query      String   @db.VarChar(200)
  searchedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, query])
  @@index([userId, searchedAt(sort: Desc)])
}

model FeedbackLog {
  id        String   @id @default(cuid())
  userId    String?
  videoId   String
  feedback  String
  createdAt DateTime @default(now())
  processed Boolean  @default(false)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([videoId])
  @@index([processed])
}

model Playlist {
  id                String          @id @default(cuid())
  userId            String
  name              String
  description       String?
  youtubePlaylistId String?
  syncEnabled       Boolean         @default(false)
  coverThumbnail    String?
  coverImage        String?         @db.Text
  shareToken        String?         @unique
  isPublic          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks            PlaylistTrack[]
  syncLogs          SyncLog[]

  @@index([userId])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  addedAt    DateTime @default(now())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id])

  @@unique([playlistId, trackId])
  @@index([playlistId])
  @@index([trackId])
}

model SavedTrack {
  id      String   @id @default(cuid())
  userId  String
  trackId String
  savedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track   Track    @relation(fields: [trackId], references: [id])

  @@unique([userId, trackId])
  @@index([userId])
  @@index([trackId])
}

model SyncLog {
  id         String   @id @default(cuid())
  userId     String?
  playlistId String?
  operation  String
  quotaUsed  Int
  trackCount Int
  status     String
  error      String?  @db.Text
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  playlist   Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([playlistId])
}

model TrackGenre {
  id      String @id @default(cuid())
  trackId String
  genre   String
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([trackId, genre])
  @@index([genre])
}

model UserGenreProfile {
  id        String @id @default(cuid())
  userId    String
  genre     String
  playCount Int    @default(0)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, genre])
  @@index([userId])
  @@index([userId, playCount])
}

model UserArtistProfile {
  id          String   @id @default(cuid())
  userId      String
  channelId   String
  channelName String
  playCount   Int      @default(0)
  totalSeconds Int     @default(0)
  lastPlayed  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId])
  @@index([channelId])
  @@index([userId, playCount])
}

model SmartMix {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.VarChar(500)
  mixType     String
  trackIds    Json
  generatedAt DateTime @default(now())
  expiresAt   DateTime
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mixType])
  @@index([userId, expiresAt])
}

model RecommendationFeedback {
  id              String   @id @default(cuid())
  userId          String
  videoId         String
  source          String
  modelVersion    String?
  action          String
  positionShown   Int
  playedSeconds   Int      @default(0)
  sessionId       String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([source, action])
  @@index([modelVersion])
  @@index([createdAt])
}

/// Currently unused — all recommendation caching uses Redis (cacheService).
/// Retained for potential DB-based fallback when Redis is unavailable (Phase 5).
model RecommendationCache {
  id          String   @id @default(cuid())
  userId      String
  sourceType  String
  sourceId    String   @default("")
  trackIds    Json
  generatedAt DateTime @default(now())
  expiresAt   DateTime

  @@unique([userId, sourceType, sourceId])
  @@index([expiresAt])
}

model UserPreferences {
  id          String   @id @default(cuid())
  userId      String   @unique
  languages   String   @db.Text
  genres      String   @db.Text
  seedArtists String   @db.Text
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
